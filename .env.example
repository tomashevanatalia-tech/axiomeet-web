# AxioMeet Frontend — Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL.
# - For LOCAL development: set to your local backend, e.g. http://localhost:8000
#   The Vite dev server will proxy /api and /oauth requests to this URL (no CORS issues).
# - For PRODUCTION build: leave unset OR set to your production URL.
#   Default fallback: https://axiomeet.io
VITE_API_URL=http://localhost:8000
